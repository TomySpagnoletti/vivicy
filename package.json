{
  "name": "vivicy",
  "version": "0.1.0",
  "description": "A visual autonomous dev factory: write the canonical spec, Vivicy extracts issues, the two-agent loop implements + reviews + verifies, all driven from the architecture map. Language- and project-agnostic.",
  "license": "MIT",
  "author": "Tomy Spagnoletti Duval",
  "type": "module",
  "private": true,
  "bin": {
    "vivicy": "factory/cli.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit",
    "clean": "node scripts/clean-artifacts.mjs",
    "test": "node scripts/clean-artifacts.mjs -- vitest run",
    "test:watch": "vitest",
    "e2e": "node scripts/clean-artifacts.mjs -- playwright test",
    "factory:typecheck": "tsc --noEmit -p factory/tsconfig.json",
    "factory:test": "node --test factory/progress-ledger.test.mjs factory/semantic-extraction-check.test.mjs factory/dev-loop.test.mjs factory/traceability-check.test.mjs factory/atomic-write.test.mjs factory/doc-baseline.test.mjs factory/extract-issues.test.mjs factory/leg-timeout.test.mjs",
    "factory:rehearsal": "node factory/dev-rehearsal.mjs",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:windows": "VIVICY_TARGET_TRIPLE=x86_64-pc-windows-msvc tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@xyflow/react": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/cli": "^2.11.3",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^6",
    "vitest": "^4.1.9"
  }
}
