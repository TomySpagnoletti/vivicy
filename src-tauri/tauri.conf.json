{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Vivicy",
  "version": "0.1.0",
  "identifier": "app.vivicy.desktop",
  "build": {
    "beforeDevCommand": "node src-tauri/scripts/prepare-sidecar.mjs",
    "beforeBuildCommand": "node src-tauri/scripts/prepare-sidecar.mjs",
    "frontendDist": "placeholder"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Vivicy",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "url": "about:blank"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/node"],
    "resources": {
      "server": "server"
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
