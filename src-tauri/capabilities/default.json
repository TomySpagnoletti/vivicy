{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Vivicy desktop capabilities: window control, the native folder dialog, and a NARROWLY scoped shell allow-list that can run ONLY the documented agent-CLI install and self-update commands plus the Next sidecar. No general shell access — every entry fixes the command and its arguments, so an arbitrary shell can never be opened.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "core:window:allow-set-focus",
    "dialog:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "install-claude",
          "cmd": "npm",
          "args": ["install", "-g", "@anthropic-ai/claude-code"]
        },
        {
          "name": "install-codex",
          "cmd": "npm",
          "args": ["install", "-g", "@openai/codex"]
        },
        {
          "name": "update-claude",
          "cmd": "claude",
          "args": ["update"]
        },
        {
          "name": "update-codex",
          "cmd": "codex",
          "args": ["update"]
        },
        {
          "name": "node",
          "sidecar": true,
          "args": true
        }
      ]
    },
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "install-claude",
          "cmd": "npm",
          "args": ["install", "-g", "@anthropic-ai/claude-code"]
        },
        {
          "name": "install-codex",
          "cmd": "npm",
          "args": ["install", "-g", "@openai/codex"]
        },
        {
          "name": "update-claude",
          "cmd": "claude",
          "args": ["update"]
        },
        {
          "name": "update-codex",
          "cmd": "codex",
          "args": ["update"]
        },
        {
          "name": "node",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
