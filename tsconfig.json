{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-e2e-demo/types/**/*.ts",
    ".next-e2e-demo/dev/types/**/*.ts",
    ".next-e2e-empty/types/**/*.ts",
    ".next-e2e-empty/dev/types/**/*.ts",
    ".next-shot-empty/types/**/*.ts",
    ".next-shot-empty/dev/types/**/*.ts",
    ".next-bootcheck/types/**/*.ts",
    ".next-bootcheck/dev/types/**/*.ts",
    ".next-e2e-onboard/types/**/*.ts",
    ".next-e2e-onboard/dev/types/**/*.ts",
    ".next-e2e-demo-chromium-desktop/types/**/*.ts",
    ".next-e2e-demo-chromium-desktop/dev/types/**/*.ts",
    ".next-e2e-demo-chromium-mobile/types/**/*.ts",
    ".next-e2e-demo-chromium-mobile/dev/types/**/*.ts",
    ".next-e2e-demo-firefox-desktop/types/**/*.ts",
    ".next-e2e-demo-firefox-desktop/dev/types/**/*.ts",
    ".next-e2e-demo-webkit-desktop/types/**/*.ts",
    ".next-e2e-demo-webkit-desktop/dev/types/**/*.ts",
    ".next-e2e-empty-chromium-desktop/types/**/*.ts",
    ".next-e2e-empty-chromium-desktop/dev/types/**/*.ts",
    ".next-e2e-empty-chromium-mobile/types/**/*.ts",
    ".next-e2e-empty-chromium-mobile/dev/types/**/*.ts",
    ".next-e2e-empty-firefox-desktop/types/**/*.ts",
    ".next-e2e-empty-firefox-desktop/dev/types/**/*.ts",
    ".next-e2e-empty-webkit-desktop/types/**/*.ts",
    ".next-e2e-empty-webkit-desktop/dev/types/**/*.ts",
    ".next-e2e-onboarding-chromium-desktop/types/**/*.ts",
    ".next-e2e-onboarding-chromium-desktop/dev/types/**/*.ts",
    ".next-e2e-onboarding-chromium-mobile/types/**/*.ts",
    ".next-e2e-onboarding-chromium-mobile/dev/types/**/*.ts",
    ".next-e2e-onboarding-firefox-desktop/types/**/*.ts",
    ".next-e2e-onboarding-firefox-desktop/dev/types/**/*.ts",
    ".next-e2e-onboarding-webkit-desktop/types/**/*.ts",
    ".next-e2e-onboarding-webkit-desktop/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "factory"
  ]
}
