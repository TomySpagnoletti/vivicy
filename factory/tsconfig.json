{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "strict": true,
    "types": ["node"],
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "../scripts/**/*.ts", "../lib/development-overlay.ts", "../lib/project-runtime.ts", "../lib/skeleton.ts", "../lib/spec-cycle.ts", "../lib/spec-kind.ts"],
  "exclude": ["../scripts/**/*.test.ts"]
}
