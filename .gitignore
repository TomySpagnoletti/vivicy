# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/test-results
/playwright-report

# vivicy control-plane runtime (supervisor logs + run-state lock)
/.vivicy-runtime

# vivicy parallel dev-loop worktrees (one git worktree per concurrently-running
# issue; created + removed by the loop, never committed)
/.vivicy-worktrees

# rehearsal self-test report (regenerated on every `factory/dev-rehearsal.mjs` run)
/factory/rehearsal/reports/

# next.js
/.next/
# Per-(shape × browser) e2e dev-server dist dirs (.next-e2e-<shape>-<browser>).
/.next-e2e-*/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# typescript
*.tsbuildinfo
next-env.d.ts

# tauri desktop shell: compiled Rust artifacts and the staged sidecar payload
# (the Next standalone server, the bundled Node binary, the placeholder frontend,
# and Tauri's generated schemas) are all build OUTPUT — regenerated by
# `src-tauri/scripts/prepare-sidecar.mjs` + `tauri build`, never committed. The
# Rust source, tauri.conf.json, capabilities, and icons ARE committed.
/src-tauri/target/
/src-tauri/server/
/src-tauri/binaries/
/src-tauri/placeholder/
/src-tauri/gen/
